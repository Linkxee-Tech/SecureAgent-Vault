# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_AUDIENCE=https://secureagentvault/api
AUTH0_ALGORITHMS=RS256
AUTH0_ISSUER=https://your-tenant.auth0.com/
# Local only: set true to bypass Auth0 checks for frontend/backend development.
DEV_BYPASS_AUTH=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vault

# Redis
REDIS_URL=redis://localhost:6379/0

# Encryption (32-byte key, raw or base64-encoded)
ENCRYPTION_KEY=replace_with_base64_or_raw_key

# JWT for short-lived vault tokens
JWT_SECRET_KEY=replace_with_strong_random_value
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_SECONDS=120

# Optional OPA integration
OPA_URL=http://opa:8181/v1/data/agent/auth/allow

# CORS
CORS_ORIGINS=http://localhost:3000

# Weather tool provider
WEATHER_PROVIDER=demo
WEATHER_API_KEY_NAME=weatherapi
